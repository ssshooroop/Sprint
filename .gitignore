*.jks
*.keystore

# Exception: committed debug keystore so CI builds share one signature
!app/debug.keystore

# OS files
.DS_Store
Thumbs.db

# Crashlytics / Firebase
fabric.properties
app/google-services.json

# Generated by kapt or annotation processors
**/build/generated/

# Misc
/captures
.externalNativeBuild
.cxx

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.SprintRunner" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_variant_color</item>
        
        <!-- Background colors -->
        <item name="android:windowBackground">@color/background_color</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_color</item>
        <item name="android:textColorSecondary">@color/text_secondary_color</item>
    </style>

    <!-- Wear OS theme -->
    <style name="Theme.SprintRunner.Wear" parent="Theme.SprintRunner">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.SprintRunner.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>